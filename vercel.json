 {
  "version": 2,
  "buildCommand": "cd artifacts/ethiobiz && pnpm run build",
  "outputDirectory": "artifacts/ethiobiz/dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}