{
  "buildCommand": "pnpm -w run typecheck:libs && pnpm --filter @workspace/ethiobiz run build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/ethiobiz/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
