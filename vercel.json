{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/ethiobiz/dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "env": {
    "VITE_SUPABASE_URL": "@vite_supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@vite_supabase_anon_key"
  },
  "rewrites": [
    {
      "source": "/((?!assets/|.*\\.).*)",
      "destination": "/artifacts/ethiobiz/dist/index.html"
    }
  ]
}+