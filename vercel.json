{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/ethiobiz/dist",
  "installCommand": "pnpm install",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
