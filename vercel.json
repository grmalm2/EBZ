{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/ethiobiz/dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}